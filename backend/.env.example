# Database (docker-compose default; swap for the Supabase URL in production)
DATABASE_URL=postgresql+psycopg://app:app@db:5432/app
# Alembic migrations must use a direct (non-pooled) connection in Supabase.
DATABASE_URL_SYNC_MIGRATIONS=postgresql+psycopg://app:app@db:5432/app

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# LLM (Gemini)
GOOGLE_API_KEY=

# App
CORS_ORIGINS=http://localhost:3000
PINNED_CURRENT_DATE=2026-06-15
